# ============================================================
# NotifyX — Environment Configuration
# ============================================================
# Required variables will cause startup failure if missing.
# Optional variables have safe defaults.
# ============================================================

# --- General ---
NODE_ENV=development
LOG_LEVEL=info

# --- MongoDB ---
# Required: Must point to a running MongoDB instance.
MONGODB_URI=mongodb://localhost:27017/notifyx

# --- Redis (Optional) ---
# If not set, in-memory cache and queue providers are used.
# Not recommended for production.
REDIS_URL=redis://localhost:6379

# --- Authentication Secrets (REQUIRED) ---
# Minimum 32 characters. Must be cryptographically random.
# Application will crash on startup if these are not set.
JWT_SECRET=your-256-bit-jwt-secret-here-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_SECRET=your-256-bit-refresh-secret-here-change-in-production
REFRESH_EXPIRES_IN=7d

# --- Admin API Key (REQUIRED) ---
# Separate from dispatch API keys. Used for admin endpoints.
ADMIN_API_KEY=ak_admin_your_separate_admin_key_here

# --- Legacy App Configuration ---
# Used by the Notification Service to validate incoming API keys.
#
# DISPATCH_APPS: comma-separated list of application names
# For each app named <APP>, provide:
#   DISPATCH_<APP>_NAME=Human-readable name
#   DISPATCH_<APP>_API_KEY=ak_live_<api_key>
#   DISPATCH_<APP>_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
#   DISPATCH_<APP>_DISCORD_COLOR=16711680
#   DISPATCH_<APP>_SLACK_WEBHOOK=https://hooks.slack.com/services/...
#   DISPATCH_<APP>_SLACK_COLOR=#58B9FF
#   DISPATCH_<APP>_SLACK_FOOTER=Custom Footer
#
DISPATCH_APPS=default
DISPATCH_DEFAULT_NAME=NotifyX_Default
DISPATCH_DEFAULT_API_KEY=ak_live_change_this_key_in_production
DISPATCH_DEFAULT_DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
DISPATCH_DEFAULT_DISCORD_COLOR=16711680
DISPATCH_DEFAULT_SLACK_WEBHOOK=https://hooks.slack.com/services/your/slack/webhook

# --- Service Ports ---
AUTH_PORT=3001
NOTIFICATION_PORT=3002
DELIVERY_PORT=3003
ANALYTICS_PORT=3004
AUDIT_PORT=3005
ADMIN_PORT=3006
WORKER_PORT=3007
GATEWAY_PORT=8080

# --- Service URLs (used by Gateway for proxying) ---
AUTH_SERVICE_URL=http://localhost:3001
NOTIFICATION_SERVICE_URL=http://localhost:3002
AUDIT_SERVICE_URL=http://localhost:3005

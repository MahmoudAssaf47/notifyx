{
  "name": "notifyx-platform",
  "version": "1.0.0",
  "private": true,
  "description": "NotifyX — Enterprise Multi-Channel Notification Platform",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MahmoudAssaf47/notifyx.git"
  },
  "author": {
    "name": "Mahmoud Assaf",
    "url": "https://github.com/MahmoudAssaf47"
  },
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run build",
    "test": "vitest run",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "prettier": "^3.2.5",
    "turbo": "^2.9.14",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
